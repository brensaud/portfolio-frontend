# =============================================================================
# Environment Variables — Portfolio Frontend
# =============================================================================
#
# Copy this file to .env.local and fill in the values for local development.
# Never commit .env.local to the repository.
#
# For production / preview, these variables are set in the Vercel project
# dashboard (Settings → Environment Variables).
#
# Variables prefixed with VITE_ are exposed to the browser bundle.
# Do NOT prefix secrets with VITE_.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────

# Canonical site URL — used for absolute links, OG images, and sitemaps.
# In development this is http://localhost:5173.
# In production this must be your custom domain (e.g. https://yourname.dev).
VITE_SITE_URL=http://localhost:5173

# Display name override (optional — defaults to the value in constants/site.ts)
VITE_SITE_NAME=Portfolio

# ─── Contact Form API (Phase 12) ─────────────────────────────────────────────

# Base URL of the FastAPI backend.
# Local development (without Docker): http://localhost:8000
# With Docker Compose: http://localhost:8000 (backend port-forwarded to 8000)
# Production: replace with your deployed API URL
VITE_API_BASE_URL=http://localhost:8000

# ─── Rate Limiting (Phase 8) ──────────────────────────────────────────────────

# Upstash Redis REST URL and token for contact form rate limiting.
# Create a database at https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ─── Analytics (Phase 12) ─────────────────────────────────────────────────────

# Plausible Analytics — your site domain (e.g. yourname.dev, no https://)
# VITE_PLAUSIBLE_DOMAIN=

# ─── GitHub API (Phase 5) ─────────────────────────────────────────────────────

# Personal access token for fetching GitHub stats (profile, repo count, etc.)
# Required scopes: public_repo, read:user
# Without this token, requests are anonymous and rate-limited to 60/hour.
# GITHUB_TOKEN=ghp_...

# GitHub username to fetch stats for
# VITE_GITHUB_USERNAME=

# ─── Testing ─────────────────────────────────────────────────────────────────

# Base URL for Playwright E2E tests.
# Override in CI to point at a production build served locally.
PLAYWRIGHT_BASE_URL=http://localhost:5173
