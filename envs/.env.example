# =============================================================================
# envs/.env.example — template for environment-specific overrides
# =============================================================================
# Copy to envs/.env.dev, envs/.env.uat, or envs/.env.prod and fill in values.
# Those files are gitignored. This file is committed as a reference.
#
# Vite usage:
#   pnpm dev --mode dev          → reads envs/.env.dev  (via vite.config.ts)
#   pnpm build --mode uat        → reads envs/.env.uat
#   pnpm build --mode production → reads envs/.env.prod
#
# All variables must be prefixed with VITE_ to be exposed in the browser.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
VITE_SITE_URL=http://localhost:5173

# ─── Contact Form API ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
